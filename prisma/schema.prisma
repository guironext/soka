// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COMITE_NATIONAL
  CENTRE_GENERAL
  CENTRE
  CHAPITRE
  DISTRICT
  GROUPE
  SOUS_GROUPE
  MEMBRE
  DEPARTMENT_COMITE_NATIONAL
  DEPARTMENT_CENTRE_GENERAL
  DEPARTMENT_CENTRE
  DEPARTMENT_CHAPITRE
  DEPARTMENT_DISTRICT
  DEPARTMENT_GROUPE
  DEPARTMENT_SOUS_GROUPE
  DEPARTMENT_MEMBRE
}

enum AccountStatus {
  PENDING_INVITATION
  PENDING_APPROVAL
  ACTIVE
}

model User {
  id                String        @id @default(cuid())
  clerkId           String        @unique
  email             String
  firstName         String?
  lastName          String?
  phone             String?
  role              Role?
  status            AccountStatus @default(PENDING_INVITATION)
  /// Target role after invitation redeem; active `role` is set when fully approved.
  pendingTargetRole Role?
  /// User who issued the invitation code used for this account (first validation step).
  invitedByUserId   String?
  invitedBy         User?         @relation("UserInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  invitedUsers      User[]        @relation("UserInvitedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issuedInvitations Invitation[] @relation("InvitationIssuer")

  approvalsGiven    OnboardingApproval[] @relation("ApprovalApprover")
  approvalsReceived OnboardingApproval[] @relation("ApprovalSubject")

  activationRequestsSent ActivationRequest[] @relation("ActivationRequestRequester")
  activationRequestsToMe ActivationRequest[] @relation("ActivationRequestRecipient")

  responsabiliteId String?
  responsabilite   Responsabilite? @relation(fields: [responsabiliteId], references: [id], onDelete: SetNull)
}

/// Recorded when a pending member asks their invitation issuer to proceed with activation / second validation.
model ActivationRequest {
  id          String   @id @default(cuid())
  requesterId String
  requester   User     @relation("ActivationRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User     @relation("ActivationRequestRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([recipientId])
  @@index([requesterId])
}

model Invitation {
  id             String    @id @default(cuid())
  /// Fonction / mission confiée à l’invité (ex. trésorerie, communication).
  responsabilite String?
  codeHash       String    @unique
  targetRole     Role
  issuerId       String
  issuer         User      @relation("InvitationIssuer", fields: [issuerId], references: [id], onDelete: Cascade)
  expiresAt      DateTime?
  maxUses        Int       @default(1)
  uses           Int       @default(0)
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  @@index([issuerId])
}

model OnboardingApproval {
  id             String   @id @default(cuid())
  subjectUserId  String
  subject        User     @relation("ApprovalSubject", fields: [subjectUserId], references: [id], onDelete: Cascade)
  approverUserId String
  approver       User     @relation("ApprovalApprover", fields: [approverUserId], references: [id], onDelete: Cascade)
  /// Role the approver had at approval time (must match validation ladder).
  approverRole   Role
  createdAt      DateTime @default(now())

  @@unique([subjectUserId, approverUserId])
  @@index([subjectUserId])
}

model Responsabilite {
  id          String   @id @default(cuid())
  niveau      String
  description String?
  niveau_responsabilite String
  centre_general String?
  centre String?
  chapitre String?
  district String?
  groupe String?
  sous_groupe String?
  department_comite_national String?
  department_centre_general String?
  department_centre String?
  department_chapitre String?
  department_district String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}
