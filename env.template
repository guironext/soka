# Copy to .env and fill values (this file is not ignored; .env is).

# For hosted Postgres (Neon, Prisma, etc.), prefer sslmode=verify-full in the URL so pg matches
# future libpq semantics and avoids sslmode deprecation warnings (see pg-connection-string).
# Example: postgresql://USER:PASSWORD@host:5432/db?sslmode=verify-full
# Neon on Vercel: prefer the pooled connection string (host contains `pooler`) to limit idle disconnects.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/soka_hub?schema=public"

# Production: your real HTTPS origin (e.g. https://soka-hub.vercel.app or custom domain).
# Do NOT set this to http://localhost:3000 on Vercel. If empty on Vercel, VERCEL_URL is used.
NEXT_PUBLIC_APP_URL=

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Use `pk_test_...` / `sk_test_...` for local dev only. For Vercel/production, create a Production
# instance in Clerk Dashboard and set `pk_live_...` + `sk_live_...` in Vercel env (otherwise you see
# "development keys" warnings and hit dev-instance limits). Webhook signing secret differs per instance.
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Host sign-in/sign-up on this app (same origin) instead of Clerk Account Portal (*.accounts.dev).
# After changing .env, align Clerk Dashboard → Configure → Paths: Sign-in URL /sign-in, Sign-up URL /sign-up.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Optional: comma-separated Clerk authorized origins (override). If unset, the app merges
# NEXT_PUBLIC_APP_URL (or VERCEL_URL on deploy) with VERCEL_URL so prod works even if APP_URL was mis-set.
# Clerk Dashboard → Domains: add the same host(s). Paths → allow https://YOUR_HOST/sign-in and /sign-up
# CLERK_AUTHORIZED_PARTIES=https://soka-hub.vercel.app,https://www.votre-domaine.com

# Optional: Clerk user IDs (user_...) that become ADMIN immediately on first user.created webhook.
SOKA_BOOTSTRAP_ADMIN_CLERK_IDS=
# Optional: admin e-mails (comma-separated) — used when the Clerk ID is not in env yet.
SOKA_BOOTSTRAP_ADMIN_EMAILS=

# Production (Vercel): set to your live origin, e.g. https://soka-rho.vercel.app — not localhost.
# NEXT_PUBLIC_APP_URL=https://soka-rho.vercel.app

# Clerk Dashboard → Sessions → Customize session token → add claims so middleware can read app state:
#   "sokaStatus": "{{user.public_metadata.sokaStatus}}"
#   "sokaRole": "{{user.public_metadata.sokaRole}}"
#   "sokaPendingTargetRole": "{{user.public_metadata.sokaPendingTargetRole}}"
# Without this, new sessions may not include metadata until refreshed; users can sign out/in after approval.
